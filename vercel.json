{\n  "buildCommand": "echo 'Static deployment ready'",\n  "outputDirectory": ".",\n  "cleanUrls": true,\n  "env": {\n    "NODE_ENV": "production"\n  },\n  "rewrites": [\n    {\n      "source": "/:path*",\n      "destination": "/anonymous_chat.html"\n    }\n  ],\n  "headers": [\n    {\n      "source": "/(.*)",\n      "headers": [\n        {\n          "key": "Cache-Control",\n          "value": "public, max-age=3600, s-maxage=3600"\n        },\n        {\n          "key": "X-Content-Type-Options",\n          "value": "nosniff"\n        }\n      ]\n    },\n    {\n      "source": "/.*\\.(js|css)$",\n      "headers": [\n        {\n          "key": "Cache-Control",\n          "value": "public, max-age=31536000, immutable"\n        }\n      ]\n    }\n  ]\n}